from __future__ import annotations

from .adapters.inbound.cli_typer import build_cli
from .adapters.outbound.json_repository import GreetingProvider
from .application.services import GreetingService
from .application.use_cases import HelloUseCase
from .infrastructure.logging_config import configure_logging


def bootstrap():
    configure_logging()

    greeting_provider = GreetingProvider()
    greeting_service = GreetingService(greeting_provider)
    hello_use_case = HelloUseCase(greeting_service)

    return build_cli(hello_use_case)
