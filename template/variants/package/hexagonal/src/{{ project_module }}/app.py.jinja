from __future__ import annotations

import typer

from .adapters.repositories.default_greeting_template_repository import (
    DefaultGreetingTemplateRepository,
)
from .application.use_cases.say_hello import SayHelloUseCase
from .cli.commands import build_cli
from .config.settings import Settings
from .infrastructure.logging_config import configure_logging


def build_app() -> typer.Typer:
    # Application composition root.
    settings = Settings()
    configure_logging()

    template_repository = DefaultGreetingTemplateRepository()
    use_case = SayHelloUseCase(template_repository=template_repository)

    return build_cli(settings=settings, use_case=use_case)
