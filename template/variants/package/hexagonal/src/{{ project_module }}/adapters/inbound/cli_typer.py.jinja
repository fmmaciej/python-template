from __future__ import annotations

import typer

from ...application.dto import HelloCommand
from ...application.use_cases import HelloUseCase


def build_cli(use_case: HelloUseCase) -> typer.Typer:
    app = typer.Typer(help="{{ project_slug }} CLI")

    @app.command()
    def hello(name: str = "world") -> None:
        result = use_case.execute(HelloCommand(name=name))
        print(result)

    return app
