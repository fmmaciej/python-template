from __future__ import annotations

from ..domain.entities import Greeting
from ..domain.ports import GreetingPort
from ..domain.value_objects import UserName


class GreetingService:
    def __init__(self, greeting_port: GreetingPort) -> None:
        self._greeting_port = greeting_port

    def greet(self, name: str) -> Greeting:
        return self._greeting_port.build_greeting(UserName(name))
