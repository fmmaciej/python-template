[project]
name = "{{ project }}"
version = "0.1.0"
description = ""
readme = "README.md"
requires-python = ">={{ python }}"
dependencies = [
{% if mode == "package" %}
  "typer>=0.16.0",
{% endif %}
]

[dependency-groups]
dev = [
  "mypy>=1.11.0",
  "pre-commit>=4.0.0",
  "pytest>=8.3.0",
  "ruff>=0.6.0",
]

{% if mode == "package" %}
[project.scripts]
{{ project }} = "{{ project_module }}.main:main"
{% endif %}

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

{% if mode == "package" %}
[tool.hatch.build.targets.wheel]
packages = ["src/{{ project_module }}"]
{% endif %}

[tool.ruff]
line-length = 100
target-version = "py{{ python | replace('.', '') }}"
src = ["src", "."]

[tool.ruff.lint]
select = [
  "E",
  "F",
  "I",
  "B",
  "UP",
  "SIM",
]
ignore = []

[tool.ruff.format]
quote-style = "double"
indent-style = "space"
line-ending = "lf"

[tool.mypy]
python_version = "{{ python }}"
strict = false
warn_unused_configs = true
warn_redundant_casts = true
warn_unused_ignores = true
warn_return_any = true
no_implicit_optional = true
check_untyped_defs = true
pretty = true
{% if mode == "package" %}
mypy_path = ["src"]
{% endif %}

[tool.pytest.ini_options]
testpaths = ["tests"]
addopts = "-ra"

[tool.uv]
package = {{ "true" if mode == "package" else "false" }}
