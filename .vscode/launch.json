{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Pytest: tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "tests",
        "-q"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "Copier: render defaults",
      "type": "debugpy",
      "request": "launch",
      "module": "copier",
      "args": [
        "copy",
        ".",
        "/tmp/tool-template-py-debug",
        "--trust",
        "--defaults"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "Script: smoke helper",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/smoke_test.py",
      "console": "integratedTerminal"
    }
  ]
}
